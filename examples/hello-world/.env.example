# ============================================================
# Hello World example — environment template
# Copy to `.env`, set the secrets, then `docker compose up -d`.
# ============================================================

# --- Core ---
ENVIRONMENT=dev
APP_TIMEZONE=UTC
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8000        # used in invite + reset emails

# --- Database ---
MYSQL_ROOT_PASSWORD=rootpw-change-me
MYSQL_DATABASE=atrium
MYSQL_USER=atrium
MYSQL_PASSWORD=atrium-change-me
DATABASE_URL=mysql+aiomysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql:3306/${MYSQL_DATABASE}

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- WebAuthn (optional, but the field must be set even if unused) ---
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Atrium Hello World
WEBAUTHN_ORIGIN=http://localhost:8000

# --- Mail ---
# Set MAIL_BACKEND=console to print outbound mail to the api logs
# (the default for dev) or =smtp to relay via a real server.
MAIL_BACKEND=console
MAIL_FROM=no-reply@example.com

# --- Hello World tick ---
# Counter increment interval in seconds. The CI smoke uses 2 so tests
# don't wait long; the demo defaults to 30 (slow enough to see).
HELLO_TICK_SECONDS=30

# --- Atrium image pin ---
# Used by compose.yaml as a build arg for the host extension Dockerfile.
# Override to test against a specific atrium release.
ATRIUM_IMAGE=ghcr.io/brendanbank/atrium:latest
