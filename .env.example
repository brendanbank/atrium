# ============================================================
# Atrium — environment template
# Copy to `.env` for local dev. Never commit the real .env.
# ============================================================

# --- Core ---
ENVIRONMENT=dev                          # dev | prod
APP_TIMEZONE=UTC
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:5173       # used in invite + reset emails

# --- Database ---
MYSQL_ROOT_PASSWORD=rootpw-change-me
MYSQL_DATABASE=atrium
MYSQL_USER=atrium
MYSQL_PASSWORD=atrium-change-me
# Async DSN consumed by the backend
DATABASE_URL=mysql+aiomysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql:3306/${MYSQL_DATABASE}

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
# Hard session limit. No refresh flow is implemented today, so after
# this many minutes the cookie expires and the user is bounced to /login.
# 10080 = 7 days.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Reserved — not currently enforced.
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Dev TOTP bootstrap (dev only, leave empty in prod) ---
# When set, smoke/e2e tooling pre-enrolls the bootstrap admin's TOTP
# with this base32 secret (already confirmed), so you can log in after
# a DB wipe without re-scanning a QR code. Generate one with
# `python -c "import pyotp; print(pyotp.random_base32())"`.
DEV_ADMIN_TOTP_SECRET=

# --- WebAuthn / FIDO2 (security keys, passkeys) ---
# Relying-party configuration. ``WEBAUTHN_RP_ID`` is the host the
# credential is bound to — must be the exact domain the browser sees,
# *without* scheme or port. ``WEBAUTHN_ORIGIN`` is the full origin the
# registration / authentication ceremony will run from. Both must match
# what the browser uses or the ceremony fails.
# Dev defaults work with `make up` on localhost:5173.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Atrium
WEBAUTHN_ORIGIN=http://localhost:5173

# --- CAPTCHA ---
# Pluggable bot challenge on unauthenticated auth endpoints (register,
# login, forgot-password). Provider + site key live in app_settings
# (admin UI -> System tab); only the secret is here, because it must
# never round-trip through the public /app-config bundle.
# Provider options: "none" (off, default), "turnstile", "hcaptcha".
# When the provider is on but this is empty, the verifier logs a
# warning and fails open — matching the HIBP posture.
CAPTCHA_SECRET=

# --- Mail ---
# MAIL_BACKEND selects how outbound mail is delivered:
#   console  — print to logs, NEVER send. Dev default.
#   smtp     — relay via host Postfix. Prod default.
#   dummy    — silently drop.
# Leave empty to auto-select based on ENVIRONMENT (dev→console, prod→smtp).
MAIL_BACKEND=

# Used only when MAIL_BACKEND=smtp.
SMTP_HOST=host.docker.internal
SMTP_PORT=25
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=no-reply@example.com
MAIL_REPLY_TO=

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000/api
VITE_DEFAULT_LANGUAGE=en

# --- Prod edge ---
# Baked into the frontend bundle as VITE_API_BASE_URL=https://$PUBLIC_HOSTNAME/api,
# so set this to the hostname the browser will hit.
PUBLIC_HOSTNAME=app.example.com
# Optional CN on the internal self-signed cert the proxy presents to
# the edge proxy. Defaults to "atrium-internal" if unset.
PROXY_CERT_CN=atrium-internal
