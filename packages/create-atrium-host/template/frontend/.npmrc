# `@brendanbank` packages are published to GitHub Packages, not the
# public npm registry. This line tells pnpm where to fetch them from.
# No auth token is required to install — the packages are public — but
# corporate proxies sometimes need an entry like:
#
#   //npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
#
# Set GITHUB_TOKEN in the shell if your network reaches github.com but
# rejects unauthenticated registry reads.
@brendanbank:registry=https://npm.pkg.github.com
