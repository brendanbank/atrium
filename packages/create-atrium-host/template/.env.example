ENVIRONMENT=dev
APP_TIMEZONE=UTC

# Long random strings. `openssl rand -hex 48` for each.
APP_SECRET_KEY=replace-me-with-openssl-rand-hex-48
JWT_SECRET=replace-me-with-openssl-rand-hex-48
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# The public URL the browser hits. Used in email links.
APP_BASE_URL=http://localhost:8000

# MySQL.
MYSQL_ROOT_PASSWORD=root-pw-change-me
MYSQL_DATABASE=__HOST_PKG__
MYSQL_USER=__HOST_PKG__
MYSQL_PASSWORD=db-pw-change-me
DATABASE_URL=mysql+aiomysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql:3306/${MYSQL_DATABASE}

# WebAuthn — the host the credential is bound to (no scheme/port) and
# the full origin the registration ceremony runs from. localhost is
# fine for dev; switch to your real hostname in prod.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=__BRAND_NAME__
WEBAUTHN_ORIGIN=http://localhost:8000

# Mail. `console` prints to stdout; switch to `smtp` and fill
# SMTP_HOST/SMTP_PORT/SMTP_USERNAME/SMTP_PASSWORD in prod.
MAIL_BACKEND=console
MAIL_FROM=no-reply@example.com

# Pin the atrium base image. X.Y for patch uptake; X.Y.Z for fully
# deterministic deploys.
ATRIUM_IMAGE=ghcr.io/brendanbank/atrium:__ATRIUM_VERSION__
